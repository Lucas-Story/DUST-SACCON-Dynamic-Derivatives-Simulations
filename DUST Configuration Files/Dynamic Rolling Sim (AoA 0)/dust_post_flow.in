basename = Postprocessing/post
data_basename = Output/saccon

analysis = {
  name = flow1
  type = flow_field

  start_res = 160
  end_res = 160
  step_res = 1
  
  format = vtk !tecplot, vtk

  variable = Velocity

  n_xyz = (/400,200,100/)
  min_xyz = (/ -1.0, -1.0, -1.0/)
  max_xyz = (/  3.0,  1.0, 0.3/)
 
}

