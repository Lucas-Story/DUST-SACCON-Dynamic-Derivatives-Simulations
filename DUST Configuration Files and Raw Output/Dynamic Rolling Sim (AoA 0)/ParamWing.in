mesh_file_type = parametric
el_type = p

mesh_symmetry = T
symmetry_point = (/0.0, 0.0, 0.0/)
symmetry_normal = (/0.0, 1.0, 0.0/)

starting_point = (/-0.8406,0.0,0.0/) !Beginning of the extruded geometry
!starting_point = (/0.0,0.0,0.0/)
reference_chord_fraction = 0.0   !fraction of chord at which the extrusion line
                                 !is placed

scaling_factor= 1.0

nelem_chord = 20                  !number of elements in chord direction 
!nelem_chord = 25                !number of elements in chord direction 

                                 !(must be one for all the component)

type_chord = cosine_le            !type of element distribution in chord
                                 ! uniform , cosine , coisneLE , cosineTE

! First section (ideally a wing rib)
chord = 1.0608             !chord length
twist = 0.0               !chord twist (deg)
airfoil = section1v2.dat    

! First region (ideally a wing bay)
span = 0.222          !span of the region
sweep = 53.0          !sweep angle (deg)
dihed = 0.0           !dihedral angle (deg)
nelem_span = 18       !number of elements in span region 
!nelem_span = 22       !number of elements in span region 
!nelem_span = 16       !number of elements in span region 
type_span = uniform   !distribution of elements in span

! Second section
chord = 0.479
twist = 0.0
airfoil = section2.dat

! Second region
span = 0.36
sweep = 53.0
dihed = 0.0
nelem_span = 20
!nelem_span = 30
!nelem_span = 13
type_span = uniform

! Third section
chord = 0.479
twist = 0
airfoil = section3.dat

! Third region
span = 0.187
sweep = 53.0
dihed = 0.0
!nelem_span = 7
!nelem_span = 11
nelem_span = 9
type_span = uniform

! Fourth section
chord = 0.005
twist = 0
airfoil = section3.dat
